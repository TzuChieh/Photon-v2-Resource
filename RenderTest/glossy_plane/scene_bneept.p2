#version 1.1.0;
sample-source(stratified) @"sample-source" = [integer samples 800];
visualizer(path-tracing) @"visualizer" = [enum sample-filter "bh"][enum estimator "bneept"][enum scheduler "bulk"];
observer(single-lens) @"observer" = [vector3 pos "2.4278171062469482 12.278207778930664 15.895854949951172"][vector3 dir "-0.07858048379421234 -0.685052752494812 -0.7242430448532104"][vector3 up-axis "-0.0738975778222084 0.7284935116767883 -0.6810554265975952"][real sensor-width-mm 36.0][real sensor-offset-mm 50.0];
option(single-frame-render-session) @"session" = [string visualizer "@visualizer"][string observer "@observer"][string sample-source "@sample-source"][enum top-level-accelerator "bvh"][vector2 frame-size "120 120"];

#import "glossy_plane.p2";
